{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dialogue Atlas",
  "version": "0.3.0",
  "identifier": "com.dialogue.atlas",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dialogue Atlas",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Productivity",
    "shortDescription": "Internal docs + canvas workspace",
    "longDescription": "Dialogue Atlas — internal documentation, brainstorming, flowcharts and mindmaps for Dialogue agency.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dialoguecreator/dialogue-atlas/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyQkY4MjhDM0E1MTc3MTcKUldRWGQxRTZqSUsvNGo1VlJlZm4vUkgxVzFQRVpMOHNCT3lvaHJxWFpoSm5KandieUFaRzF3MVUK"
    }
  }
}
